# NASA FIRMS — Public Globe VIIRS hotspots
#
# Recommended (matches FIRMS US/Canada CSV builder). Single VIIRS feed: VIIRS_NOAA21_NRT.
# Example path:
#   .../usfs/api/area/csv/<MAP_KEY>/VIIRS_NOAA21_NRT/world/1/<YYYY-MM-DD>
# Docs: https://firms.modaps.eosdis.nasa.gov/usfs/api/area/

VITE_FIRMS_MAP_KEY=

# CSV host (defaults to USFS gateway above).
# Legacy global: https://firms.modaps.eosdis.nasa.gov/api/area/csv
# VITE_FIRMS_AREA_CSV_BASE=

# Area: omit = default `world` keyword. Only set us-canada for wide NA bbox.
# VITE_FIRMS_AREA=us-canada

# Day range NASA allows 1…5 here (default 1).
# VITE_FIRMS_DAY_RANGE=1

# Date segment appended as /YYYY-MM-DD (UTC calendar day unless fixed below).
# VITE_FIRMS_DATE=2026-05-16
# To call without trailing date (= most recent sliding window): VITE_FIRMS_APPEND_DATE=false

# CAL FIRE Incident API — dev uses Vite proxy `/cal-fire-api` (see vite.config.js) to bypass CORS.
# Incidents shown only if Started or Updated is within ~24h of page load (see firmsLive.js).
# Production previews may need same proxy on your host, or override with full URL pointing at your gateway:
# VITE_CAL_FIRE_INCIDENT_LIST_URL=https://your-host/your-proxy?...
